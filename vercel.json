{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb",
                "includeFiles": [
                    "main.py",
                    "config.py",
                    "app/**/*.py",
                    "app/**/__init__.py",
                    "knowledge/**/*.json",
                    "templates/**/*.html",
                    "static/**/*"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.py"
        }
    ]
}
